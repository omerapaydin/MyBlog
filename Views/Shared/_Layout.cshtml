<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ömer Apaydın | ByRoot Blog</title>

    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
          rel="stylesheet" />
</head>

<body>
    <header class="navbar">
        <a href="index.html" class="nav-logo">
            Ömer Apaydın<span class="slash"> / </span><small>ByRoot</small>
        </a>

        <nav>
            <a href="#about">Hakkımda</a>
            <a href="#fields">Alanlar</a>
            <a href="#projects">Projeler</a>
            <a href="#blog">Blog</a>
            <a href="#contact">İletişim</a>
        </nav>
    </header>
    @RenderBody()
    <footer>
        <p>© 2026 ByRoot. Tüm hakları saklıdır.</p>
    </footer>
    <script>
            const filterButtons = document.querySelectorAll(".filter-btn");
            const projectRows = document.querySelectorAll(".project-row");

            filterButtons.forEach(button => {
                button.addEventListener("click", () => {
                    const filterValue = button.getAttribute("data-filter");

                    filterButtons.forEach(btn => btn.classList.remove("active"));
                    button.classList.add("active");

                    projectRows.forEach(project => {
                        const projectCategory = project.getAttribute("data-category");

                        if (filterValue === "all" || projectCategory === filterValue) {
                            project.style.display = "flex";
                        } else {
                            project.style.display = "none";
                        }
                    });
                });
            });
    </script>
    <script>
            const projectRows = document.querySelectorAll(".project-row");
            const projectPagination = document.getElementById("projectPagination");

            const projectsPerPage = 3;
            let currentPage = 1;

            const totalPages = Math.ceil(projectRows.length / projectsPerPage);

            function showProjectPage(page) {
                currentPage = page;

                projectRows.forEach((project, index) => {
                    const start = (page - 1) * projectsPerPage;
                    const end = start + projectsPerPage;

                    project.style.display =
                        index >= start && index < end ? "flex" : "none";
                });

                createProjectPagination();
            }

            function createProjectPagination() {
                projectPagination.innerHTML = "";

                for (let i = 1; i <= totalPages; i++) {
                    const button = document.createElement("button");

                    button.textContent = i;
                    button.classList.add("project-page-btn");

                    if (i === currentPage) {
                        button.classList.add("active");
                    }

                    button.addEventListener("click", () => {
                        showProjectPage(i);

                        document.getElementById("projects").scrollIntoView({
                            behavior: "smooth",
                            block: "start"
                        });
                    });

                    projectPagination.appendChild(button);
                }
            }

            showProjectPage(1);
    </script>
</body>

</html>