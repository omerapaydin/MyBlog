@model List<Project>
<section class="hero-profile">
    <div class="hero-profile-layout">

        <!-- MAIN PROFILE CARD -->
        <div class="profile-card">
            <div class="side-note side-left">
                <i class="bi bi-code-slash"></i>
                <span>Full-Stack</span>
            </div>

            <div class="side-note side-right">
                <i class="bi bi-shield-lock"></i>
                <span>Web Security</span>
            </div>

            <div class="orbit-dot dot-one"></div>
            <div class="orbit-dot dot-two"></div>

            <div class="profile-img-box">
                <img src="~/images/omerapaydin.jpg" alt="Ömer Apaydın" />
                <span class="profile-icon">
                    <i class="bi bi-person-fill"></i>
                </span>
            </div>

            <span class="mini-badge">ByRoot Founder</span>

            <h1>Ömer Apaydın</h1>

            <h2>
                ByRoot Kurucusu / Bilgisayar Mühendisi / Software Developer
            </h2>

            <p>
                ByRoot’un kurucusu olarak modern web siteleri, e-ticaret sistemleri,
                siber güvenlik ve özel yazılım çözümleri geliştiriyorum. Teknoloji,
                tasarım ve güvenliği bir araya getirerek markalar için güçlü dijital
                deneyimler oluşturuyorum.
            </p>

            <div class="profile-tags">
                <span>Web & .NET</span>
                <span>iOS & Swift</span>
                <span>Cyber Security</span>
                <span>Project Management</span>
                <span>UX/UI Design</span>
            </div>

            <div class="hero-buttons">
                <a href="#projects" class="btn-dark">Projelerimi Gör</a>
                <a href="#contact" class="btn-light">İletişim Kur</a>
            </div>
        </div>

        <!-- SMALL BYROOT CARD -->
        <aside class="byroot-profile-card">
            <div class="byroot-orbit byroot-orbit-one"></div>
            <div class="byroot-orbit byroot-orbit-two"></div>

            <div class="byroot-logo-box">
                <div class="byroot-logo">
                    <img src="~/images/ByRoot.jpg" alt="ByRoot Logo" />
                </div>

                <span class="byroot-logo-icon">
                    <i class="bi bi-buildings-fill"></i>
                </span>
            </div>

            <span class="mini-badge">Digital Studio</span>

            <h2>ByRoot</h2>

            <h3>Web, Software & Security</h3>

            <p>
                Modern web siteleri, e-ticaret çözümleri, güvenli yazılım
                altyapıları ve markalara özel dijital deneyimler geliştirir.
            </p>

            <div class="byroot-tags">
                <span>.NET</span>
                <span>Web</span>
                <span>E-Commerce</span>
                <span>Security</span>
                <span>SEO</span>
            </div>

            <a href="/Home/ByRootDetay" class="byroot-card-btn">
                ByRoot
                <i class="bi bi-arrow-right"></i>
            </a>

            <a href="https://byroot.org" target="_blank" class="byroot-site-link">
                byroot.org
            </a>
        </aside>

    </div>
</section>

<section id="about" class="section">
    <div class="section-title">
        <span>01</span>
        <h2>Ben Kimim?</h2>
    </div>

    <div class="text-card">
        <p>
            Merhaba, ben Ömer. Bilgisayar mühendisliği geçmişine sahip, web
            geliştirme, siber güvenlik, iOS uygulama geliştirme ve proje yönetimi
            alanlarında çalışan bir yazılım geliştiriciyim.
        </p>

        <p>
            ByRoot ile amacım; kişisel markalara, işletmelere ve girişimlere
            modern, sade, hızlı ve güvenli dijital çözümler sunmak.
        </p>
    </div>
</section>

<section id="fields" class="section">
    <div class="section-title">
        <span>02</span>
        <h2>Çalıştığım Alanlar</h2>
    </div>

    <div class="grid-3">
        <div class="service-card">
            <i class="bi bi-code-slash"></i>
            <h3>Web & .NET Development</h3>
            <p>
                ASP.NET Core MVC, Entity Framework, Identity, admin panel,
                veritabanı ve dinamik web uygulamaları geliştiriyorum.
            </p>
        </div>

        <div class="service-card">
            <i class="bi bi-phone"></i>
            <h3>iOS & Swift</h3>
            <p>
                Swift, SwiftUI ve mobil uygulama geliştirme alanında projeler ve
                arayüz çalışmaları yapıyorum.
            </p>
        </div>

        <div class="service-card">
            <i class="bi bi-shield-lock"></i>
            <h3>Cyber Security</h3>
            <p>
                Penetrasyon testleri, web uygulama güvenliği, zafiyet analizi,
                güvenli kod inceleme ve raporlama süreçleri üzerine çalışıyorum.
            </p>
        </div>

        <div class="service-card">
            <i class="bi bi-kanban"></i>
            <h3>Project Management</h3>
            <p>
                Proje planlama, süreç yönetimi, ihtiyaç analizi ve sürdürülebilir
                geliştirme yaklaşımıyla çalışıyorum.
            </p>
        </div>

        <div class="service-card">
            <i class="bi bi-palette"></i>
            <h3>UX/UI Design</h3>
            <p>
                Sade, kaliteli, modern ve kullanıcı dostu arayüzler tasarlamaya önem
                veriyorum.
            </p>
        </div>

        <div class="service-card">
            <i class="bi bi-search"></i>
            <h3>SEO & Performance</h3>
            <p>
                Web sitelerinin hızlı, erişilebilir, mobil uyumlu ve arama
                motorlarına uygun olmasına dikkat ediyorum.
            </p>
        </div>
    </div>
</section>

<section class="section">
    <div class="section-title">
        <span>03</span>
        <h2>Sertifikalar</h2>
    </div>

    <div class="list-box">
        <div class="list-item">
            <div>
                <h3>SEO Eğitimi</h3>
                <p>
                    Arama motoru optimizasyonu, teknik SEO ve içerik optimizasyonu.
                </p>
            </div>
            <span>SEO</span>
        </div>

        <div class="list-item">
            <div>
                <h3>Siber Güvenlik Stajı</h3>
                <p>
                    Linux güvenliği, SSH hardening, zafiyet analizi ve raporlama.
                </p>
            </div>
            <span>Security</span>
        </div>

        <div class="list-item">
            <div>
                <h3>Web Development</h3>
                <p>
                    ASP.NET Core, MVC, Entity Framework ve modern web mimarileri.
                </p>
            </div>
            <span>Web</span>
        </div>
    </div>
</section>

<section id="projects" class="section">
    <div class="section-title">
        <span>04</span>
        <h2>Projelerim</h2>
    </div>

    <div class="project-list">

        @foreach (var prj in Model)
        {
            <div class="project-row">
                <div class="project-image">
                    <img src="~/images/@prj.Image" alt="ByRoot Projesi">
                </div>

                <div class="project-content">
                    <span class="category">@prj.Category</span>
                    <h3>@prj.Title</h3>
                    <p>
                        @prj.Description
                    </p>

                    @* <div class="small-tags">
                        <span>Web & .NET</span>
                        <span>MVC</span>
                        <span>Identity</span>
                    </div> *@
                </div>

                <a href="@prj.Link" href="project-detail.html">Detay</a>
            </div>
        }


    </div>

    <div class="project-pagination" id="projectPagination"></div>
</section>


<section id="contact" class="section contact-section">
    <div class="contact-card">
        <h2>Birlikte Çalışalım</h2>
        <p>
            Web sitesi, e-ticaret, güvenlik veya özel yazılım projen varsa benimle
            iletişime geçebilirsin.
        </p>

        <div class="contact-links">
            <a href="https://www.instagram.com/omerapaydin"><i class="bi bi-instagram"></i> Instagram</a>
            <a href="https://www.linkedin.com/in/omerapaydin/"><i class="bi bi-linkedin"></i> LinkedIn</a>
            <a href="https://github.com/omerapaydin"><i class="bi bi-github"></i> GitHub</a>
            <a href="mailto:omerapaydin90@gmail.com"><i class="bi bi-envelope"></i> Mail</a>
        </div>
    </div>
</section>